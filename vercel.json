{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.abhinavgoldandsilver.com/api/:path*"
    },
    {
      "source": "/music/:path*",
      "destination": "https://api.abhinavgoldandsilver.com/music/:path*"
    },
    {
      "source": "/api-news/:path*",
      "destination": "https://www.investing.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
