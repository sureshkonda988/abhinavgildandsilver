{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.abhinavgoldandsilver.com/api/:path*"
    },
    {
      "source": "/music/:path*",
      "destination": "https://api.abhinavgoldandsilver.com/music/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
